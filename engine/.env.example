# Универсальная оболочка без продуктовой темы из content/repo_docs/brand/theme.css (только цвета из App.css).
# Перезапустите dev-сервер после смены.
# VITE_DOCS_USE_CONTENT_THEME=0

# Заголовок вкладки браузера (подставляется в index.html при dev/build). Не задано — «MedControl — Документация».
# VITE_DOCS_SITE_TITLE=Мой продукт — Документация

# Логотип в шапке (опционально). Пустая строка = скрыть логотип (универсальная оболочка).
# По умолчанию (переменная не задана): /content/images/logo/logo_3.png
# VITE_DOCS_LOGO_URL=
# VITE_DOCS_LOGO_URL=/content/images/logo/другой.png

# Подпись ссылки с логотипом (доступность). Не задано — «На главную документации».
# VITE_DOCS_HOME_ARIA_LABEL=Мой продукт — на главную

# Favicon: путь от корня сайта (после BASE_URL) или полный https://… Не задано — %BASE_URL%icons/favicon.svg
# VITE_DOCS_FAVICON_URL=content/repo_docs/brand/favicon.svg
# VITE_DOCS_FAVICON_TYPE=image/svg+xml
# VITE_DOCS_FAVICON_TYPE=image/png

# PDF-сервис (Playwright). Подробно: pdf-server/README.md
#
# Локально: удобнее одна команда из engine — npm run dev:with-pdf (Vite + pdf-server).
# В npm run dev браузер ходит на POST /api/pdf того же origin (прокси Vite → :3001).
# Не задавайте VITE_PDF_SERVICE_URL=http://127.0.0.1:3001 для локальной разработки —
# это заставляло бы браузер стучаться на другой «сайт» и давало Failed to fetch; движок в DEV
# сам использует /api/pdf, даже если такая строка есть в .env.local.
#
# Укажите VITE_PDF_SERVICE_URL только если в DEV тестируете удалённый сервис печати:
# VITE_PDF_SERVICE_URL=https://ваш-pdf-сервис.example.com
#
# Production / GitHub Pages: статический сайт не содержит Node — pdf-server нужно задеплоить
# отдельно (VPS, Railway, Fly.io и т.д.), затем при СБОРКЕ фронта указать его URL:
#   VITE_PDF_SERVICE_URL=https://ваш-pdf-сервис.example.com
# На pdf-server задать ALLOWED_HOSTS с хостом документации (например mash018030-alt.github.io)
# и CORS_ORIGIN=https://mash018030-alt.github.io (или ваш Origin; при подпапке — с /repo-name при необходимости).
# После смены переменных: npm run build и заново выложить dist.
